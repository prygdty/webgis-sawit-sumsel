// File: prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Tabel untuk menyimpan data Pengguna (RBAC: Admin & User biasa)
model User {
  id        String   @id @default(uuid())
  name      String?
  email     String   @unique
  password  String
  role      String   @default("USER") // Nanti kita bisa set menjadi "ADMIN"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Tabel untuk menyimpan data 17 Kabupaten/Kota (CRUD oleh Admin)
model Region {
  id          Int      @id @default(autoincrement())
  name        String
  province    String   @default("SUMATERA SELATAN")
  area        Float    // Luas Lahan (Ha)
  elevation   Float    // Elevasi (mdpl)
  rainfall    Float    // Curah hujan (mm/th)
  description String?  // Keterangan Analitik
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}